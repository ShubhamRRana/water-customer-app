# Supabase Configuration
# Get these values from: Supabase Dashboard  Settings  API
# 
#  SECURITY: This file is committed to Git!
#  NEVER put real credentials here - only placeholder values!
#  Copy this file to .env and replace placeholders with your actual values
#
#  Before release builds, run: npm run secrets:check
#  (ensures service role / Razorpay secrets are not present under src/)

EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Auth success page URL (add to Supabase Redirect URLs)
# Used as redirect after email verification. Default: https://tankerhub.in/auth/success
EXPO_PUBLIC_AUTH_SUCCESS_URL=https://tankerhub.in/auth/success

# Password reset: deep link that opens the app so the user sets a new password in-app.
# Must match app.config.js scheme and be listed in Supabase Auth → URL Configuration → Redirect URLs.
EXPO_PUBLIC_PASSWORD_RESET_REDIRECT_URL=wtccustomer://reset-password

# Razorpay (client — Key ID only; secret stays in Supabase Edge Function secrets)
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id_here

# Server-side only (for migration scripts, not used in app)
#  NEVER commit the actual service_role key to Git
#  This is a placeholder - replace with real value only in .env file
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------------------------------
# Supabase Edge Functions (Razorpay payments) — set in Dashboard:
# Project Settings → Edge Functions → Secrets (not EXPO_PUBLIC_*)
#
# RAZORPAY_KEY_ID=rzp_test_your_key_id_here
# RAZORPAY_KEY_SECRET=your_key_secret_here
# RAZORPAY_WEBHOOK_SECRET=<set after creating webhook in Razorpay Dashboard>
# -----------------------------------------------------------------------------
