# Supabase Configuration
# Get these values from: Supabase Dashboard  Settings  API
# 
#  SECURITY: This file is committed to Git!
#  NEVER put real credentials here - only placeholder values!
#  Copy this file to .env and replace placeholders with your actual values

EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Auth success page URL (add to Supabase Redirect URLs)
# Used as redirect after email verification. Default: https://tankerhub.in/auth/success
EXPO_PUBLIC_AUTH_SUCCESS_URL=https://tankerhub.in/auth/success

# Password reset: where the user lands after clicking the link in the reset email.
# Point this to a page that lets them SET A NEW PASSWORD (not just "authentication successful").
# Option 1: Host public/reset-password.html at e.g. https://yoursite.com/auth/reset-password
#   and set EXPO_PUBLIC_PASSWORD_RESET_REDIRECT_URL=https://yoursite.com/auth/reset-password
#   In that HTML, set window.SUPABASE_URL and window.SUPABASE_ANON_KEY before the script runs.
# Option 2: Use a deep link so the app opens (e.g. myapp://reset-password) and set the password in-app.
EXPO_PUBLIC_PASSWORD_RESET_REDIRECT_URL=https://yoursite.com/auth/reset-password

# Server-side only (for migration scripts, not used in app)
#  NEVER commit the actual service_role key to Git
#  This is a placeholder - replace with real value only in .env file
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------------------------------
# Supabase Edge Functions (Paytm subscription payments) — set in Dashboard:
# Project Settings → Edge Functions → Secrets (not EXPO_PUBLIC_*)
#
# PAYTM_MID=your_merchant_id
# PAYTM_KEY=your_merchant_key
# PAYTM_WEBSITE=DEFAULT
# PAYTM_HOST=https://securegw-stage.paytm.in
# # PAYTM_HOST=https://securegw.paytm.in
# CALLBACK_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/payment-callback
#
# CALLBACK_URL must match the payment-callback function URL Paytm redirects to.
#
# Optional — Paytm hosted checkout URL for the app WebView (must match PAYTM_HOST in Edge secrets):
# EXPO_PUBLIC_PAYTM_CHECKOUT_BASE_URL=https://securegw-stage.paytm.in
# # EXPO_PUBLIC_PAYTM_CHECKOUT_BASE_URL=https://securegw.paytm.in
# -----------------------------------------------------------------------------
